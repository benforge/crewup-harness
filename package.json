{
  "name": "crewup-harness",
  "version": "0.1.2",
  "description": "CrewUp: a reusable AI workflow harness for project-agnostic agent collaboration.",
  "author": "Ben",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xiaoxing92/crewup-harness.git"
  },
  "homepage": "https://github.com/xiaoxing92/crewup-harness#readme",
  "bugs": {
    "url": "https://github.com/xiaoxing92/crewup-harness/issues"
  },
  "keywords": [
    "ai",
    "agent",
    "workflow",
    "harness",
    "codex",
    "claude",
    "automation"
  ],
  "bin": {
    "crewup": "./bin/crewup.mjs",
    "crewup-harness": "./bin/crewup.mjs",
    "harness": "./bin/crewup.mjs"
  },
  "files": [
    "AGENTS.md",
    ".harness",
    "bin",
    "assets",
    "README.md",
    "README.en.md",
    "CONTRIBUTING.md",
    "SECURITY.md",
    "CHANGELOG.md",
    "docs",
    "examples"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "test": "npm run harness:check && npm --prefix examples/minimal-node test",
    "harness:check": "node .harness/scripts/check.mjs",
    "harness:inspect": "node .harness/scripts/inspect.mjs",
    "harness:init": "node .harness/scripts/init.mjs",
    "harness:doctor": "node .harness/scripts/doctor.mjs",
    "harness:run": "node .harness/scripts/run.mjs",
    "harness:finalize": "node .harness/scripts/finalize.mjs",
    "harness:finish": "node .harness/scripts/finish.mjs",
    "harness:overlay-report": "node .harness/scripts/overlay-report.mjs",
    "harness:status": "node .harness/scripts/status.mjs",
    "harness:intake": "node .harness/scripts/intake.mjs",
    "harness:backlog-item": "node .harness/scripts/backlog-item.mjs",
    "harness:new-run": "node .harness/scripts/new-run.mjs",
    "harness:prepare-run": "node .harness/scripts/prepare-run.mjs",
    "harness:transition": "node .harness/scripts/transition.mjs",
    "harness:gate-check": "node .harness/scripts/gate-check.mjs",
    "harness:verify": "node .harness/scripts/verify.mjs",
    "harness:context-pack": "node .harness/scripts/context-pack.mjs",
    "harness:desktop-plan": "node .harness/scripts/desktop-plan.mjs",
    "harness:desktop-light": "node .harness/scripts/desktop-light.mjs",
    "harness:requirements-interview": "node .harness/scripts/requirements-interview.mjs",
    "harness:requirements-plan": "node .harness/scripts/requirements-plan.mjs",
    "harness:native-plan": "node .harness/scripts/native-plan.mjs",
    "harness:native-state": "node .harness/scripts/native-state.mjs",
    "harness:repair-state": "node .harness/scripts/repair-state.mjs",
    "harness:report": "node .harness/scripts/report.mjs",
    "harness:dashboard": "node .harness/scripts/dashboard.mjs",
    "harness:knowledge": "node .harness/scripts/knowledge.mjs",
    "harness:knowledge-select": "node .harness/scripts/knowledge-select.mjs",
    "harness:cleanup": "node .harness/scripts/cleanup.mjs",
    "harness:next": "node .harness/scripts/next.mjs",
    "harness:archive-commit": "node .harness/scripts/archive-commit.mjs",
    "harness:archive-status": "node .harness/scripts/archive-status.mjs",
    "harness:changed-files": "node .harness/scripts/changed-files.mjs",
    "harness:token-ledger": "node .harness/scripts/token-ledger.mjs",
    "harness:skills": "node .harness/scripts/skills-report.mjs",
    "harness:skills:resolve": "node .harness/scripts/skills-resolve.mjs",
    "harness:skills:install": "node .harness/scripts/skills-install.mjs",
    "harness:skills:install-exact": "node .harness/scripts/skills-install.mjs --exact",
    "harness:skills:audit": "node .harness/scripts/skills-audit.mjs",
    "harness:product-sync": "node .harness/scripts/product-sync.mjs",
    "harness:orchestrate": "node .harness/scripts/orchestrate.mjs"
  },
  "dependencies": {
    "@openai/agents": "0.11.5",
    "yaml": "^2.6.1",
    "zod": "^4.0.0"
