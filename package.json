{
  "name": "crewup-harness",
  "version": "0.4.6",
  "description": "CrewUp: a reusable AI workflow harness for project-agnostic agent collaboration.",
  "author": "Ben",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/benforge/crewup-harness.git"
  },
  "homepage": "https://github.com/benforge/crewup-harness#readme",
  "bugs": {
    "url": "https://github.com/benforge/crewup-harness/issues"
  },
  "keywords": [
    "ai",
    "agent",
    "workflow",
    "harness",
    "codex",
    "claude",
    "automation"
  ],
  "bin": {
    "crewup": "bin/crewup.mjs",
    "crewup-harness": "bin/crewup.mjs",
    "harness": "bin/crewup.mjs"
  },
  "files": [
    "AGENTS.md",
    ".harness",
    "!.harness/project/*.json",
    "!.harness/project/*.yaml",
    "!.harness/project/rules/**",
    "!.harness/reports/**",
    ".harness/reports/.gitkeep",
    "!.harness/dashboard/**",
    ".harness/dashboard/.gitkeep",
    "!.harness/runs/**",
    ".harness/runs/.gitkeep",
    "!.harness/knowledge/*.json",
    "!.harness/knowledge/*.md",
    ".harness/knowledge/.gitkeep",
    ".harness/knowledge/README.md",
    ".harness/knowledge/lessons-learned.md",
    "bin",
    "assets",
    "README.md",
    "README.en.md",
    "CONTRIBUTING.md",
    "SECURITY.md",
    "CHANGELOG.md",
    "docs",
    "examples"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "test": "npm run harness:check && npm --prefix examples/minimal-node test",
    "test:install-flow": "node .harness/scripts/test-install-flow.mjs",
    "test:local-install": "node .harness/scripts/test-install-flow.mjs",
    "test:pack-install": "npm run test:install-flow && node .harness/scripts/test-flow.mjs",
    "release:preflight": "npm run harness:check && npm test && npm run test:pack-install && npm pack --dry-run",
    "test:flow": "node .harness/scripts/test-flow.mjs",
    "harness:check": "node .harness/scripts/check.mjs",
    "harness:inspect": "node .harness/scripts/inspect.mjs",
    "harness:init": "node .harness/scripts/init.mjs",
    "harness:doctor": "node .harness/scripts/doctor.mjs",
    "harness:run": "node .harness/scripts/run.mjs",
    "harness:finish": "node .harness/scripts/finish.mjs",
    "harness:archive": "node .harness/scripts/archive.mjs",
    "harness:cancel": "node .harness/scripts/cancel.mjs",
    "harness:continue": "node .harness/scripts/continue-run.mjs",
    "harness:status": "node .harness/scripts/status.mjs",
    "harness:explain": "node .harness/scripts/flow-health.mjs",
    "harness:drive": "node .harness/scripts/drive.mjs",
    "harness:prepare-run": "node .harness/scripts/prepare-run.mjs",
    "harness:spec-freeze": "node .harness/scripts/spec-freeze.mjs",
    "harness:transition": "node .harness/scripts/transition.mjs",
    "harness:gate-check": "node .harness/scripts/gate-check.mjs",
    "harness:audit": "node .harness/scripts/orchestration-audit.mjs",
    "harness:context-pack": "node .harness/scripts/context-pack.mjs",
    "harness:agent-plan": "node .harness/scripts/native-plan.mjs",
    "harness:next-agent": "node .harness/scripts/next-agent.mjs",
    "harness:clarify": "node .harness/scripts/clarify.mjs",
    "harness:native-plan": "node .harness/scripts/native-plan.mjs",
    "harness:native-state": "node .harness/scripts/native-state.mjs",
    "harness:repair-plan": "node .harness/scripts/repair-plan.mjs",
    "harness:repair-state": "node .harness/scripts/repair-state.mjs",
    "harness:tool-fallback": "node .harness/scripts/tool-fallback.mjs",
    "harness:report": "node .harness/scripts/report.mjs",
    "harness:learn": "node .harness/scripts/learn.mjs",
    "harness:learn-promote": "node .harness/scripts/learn-promote.mjs",
    "harness:dashboard": "node .harness/scripts/dashboard.mjs",
    "harness:knowledge": "node .harness/scripts/knowledge.mjs",
    "harness:knowledge-select": "node .harness/scripts/knowledge-select.mjs",
    "harness:archive-commit": "node .harness/scripts/archive-commit.mjs",
    "harness:changed-files": "node .harness/scripts/changed-files.mjs",
    "harness:token-ledger": "node .harness/scripts/token-ledger.mjs",
    "harness:dev-service": "node .harness/scripts/dev-service.mjs",
    "harness:preview-smoke": "node .harness/scripts/preview-smoke.mjs",
    "harness:test-flow": "node .harness/scripts/test-flow.mjs",
    "harness:test-install-flow": "node .harness/scripts/test-install-flow.mjs",
    "harness:product-sync": "node .harness/scripts/product-sync.mjs"
  },
  "dependencies": {
    "@openai/agents": "0.11.5",
    "yaml": "^2.6.1",
    "zod": "^4.0.0"
  }
}
